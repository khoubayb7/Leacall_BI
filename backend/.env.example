POSTGRES_DB=bi_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

LEACALL_BI_API_KEY=


# ── Celery Beat Schedule ──────────────────────────────────────────────────────
# Configure the schedule time for periodic refresh jobs (in UTC)

# KPI Beat schedule (default: 2:00 UTC daily)
KPI_BEAT_HOUR_UTC=2
KPI_BEAT_MINUTE_UTC=0

# ETL Beat schedule (default: 1:00 UTC daily)
# This runs nightly ETL refresh for all active client campaigns
ETL_BEAT_HOUR_UTC=1
ETL_BEAT_MINUTE_UTC=0

celery -A ETL_Project worker -l info --pool=solo
celery -A ETL_Project beat -l info